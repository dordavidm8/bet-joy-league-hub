PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# Set to true to run without a real DB or Firebase (mock data)
STUB_MODE=true

# PostgreSQL — local or Railway
DATABASE_URL=postgresql://localhost:5432/derbyup

# Firebase — path to service account JSON file
FIREBASE_CREDENTIAL_PATH=../kickoff-c1b6a-firebase-adminsdk-fbsvc-e517b6e065.json

# Admin UIDs (comma-separated Firebase UIDs)
ADMIN_UIDS=

# Groq API
GROQ_API_KEY=

# The Odds API
THE_ODDS_API_KEY=

# Secrets encryption master key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep this ONLY in Railway env vars, never commit it
SECRETS_MASTER_KEY=
